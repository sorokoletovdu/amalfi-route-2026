---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import DaySection from '../components/DaySection.astro';

const entries = await getCollection('route');
const route = entries[0]; // single-file collection
if (!route) throw new Error('No route entry found in src/content/route/');

const { title, description, days } = route.data;
const base = import.meta.env.BASE_URL;
---

<Layout title={title} description={description}>
  <!-- ── Nav / Print button ──────────────────────────────── -->
  <header class="no-print sticky top-0 z-10 border-b border-[var(--color-sea-light)] bg-white/90 backdrop-blur">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
      <span class="font-heading text-lg font-semibold text-[var(--color-sea-deep)]">
        ⚓ {title}
      </span>
      <div class="flex gap-2">
        <a
          href={`${base}amalfi-route.pdf`}
          download
          class="rounded-md border border-[var(--color-sea)] px-3 py-1.5 text-sm font-medium text-[var(--color-sea)] hover:bg-[var(--color-sea-pale)] transition-colors"
        >
          ↓ Download PDF
        </a>
        <button
          onclick="window.print()"
          class="rounded-md bg-[var(--color-sea)] px-3 py-1.5 text-sm font-medium text-white hover:bg-[var(--color-sea-deep)] transition-colors"
        >
          🖨 Print
        </button>
      </div>
    </div>
  </header>

  <!-- ── Main content ────────────────────────────────────── -->
  <main class="mx-auto max-w-4xl px-4 py-8">
    <!-- Cover / intro -->
    <div class="mb-10 rounded-xl bg-[var(--color-sea-pale)] p-6">
      <h1 class="font-heading text-3xl font-bold text-[var(--color-sea-deep)] sm:text-4xl">
        {title}
      </h1>
      {description && (
        <p class="mt-3 text-[var(--color-muted)]">{description}</p>
      )}
      <p class="mt-2 text-sm text-[var(--color-muted)]">
        {days.length} days · {days.reduce((acc, d) => acc + (d.distance_nm ?? 0), 0)} nm total
      </p>
    </div>

    <!-- Day sections -->
    <div class="space-y-12">
      {days.map((day) => <DaySection day={day} />)}
    </div>
  </main>
</Layout>
