---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import DaySection from '../components/DaySection.astro';
import RouteDiagram from '../components/RouteDiagram.astro';
import SciroccoSection from '../components/SciroccoSection.astro';

const entries = await getCollection('route');
const route = entries[0]; // single-file collection
if (!route) throw new Error('No route entry found in src/content/route/');

const { title, subtitle, dates, home_base, boat, crew, rules, days, scirocco_branch } = route.data;
const base = import.meta.env.BASE_URL;
---

<Layout title={title}>
  <!-- ── Nav / Print button ──────────────────────────────── -->
  <header class="no-print sticky top-0 z-10 border-b border-[var(--color-sea-light)] bg-white/90 backdrop-blur">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
      <span class="font-heading text-base font-semibold text-[var(--color-sea-deep)] min-w-0 flex-1 truncate mr-3 sm:text-lg">
        ⚓ {title}
      </span>
      <div class="flex shrink-0 gap-2">
        <a
          href={`${base.replace(/\/?$/, '/')}amalfi-route.pdf`}
          download
          class="rounded-md border border-[var(--color-sea)] px-3 py-1.5 text-sm font-medium text-[var(--color-sea)] transition-colors hover:bg-[var(--color-sea-pale)]"
        >
          ↓ PDF
        </a>
        <button
          onclick="window.print()"
          class="rounded-md bg-[var(--color-sea)] px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-[var(--color-sea-deep)]"
        >
          🖨 Печать
        </button>
      </div>
    </div>
  </header>

  <!-- ── Main content ────────────────────────────────────── -->
  <main class="mx-auto max-w-4xl px-4 py-8">

    <!-- Cover card -->
    <div class="mb-10 rounded-xl bg-[var(--color-sea-pale)] p-6">
      <h1 class="font-heading text-3xl font-bold text-[var(--color-sea-deep)] sm:text-4xl">
        {title}
      </h1>
      {subtitle && <p class="mt-1 text-lg text-[var(--color-sea)]">{subtitle}</p>}

      <!-- Boat + crew metadata -->
      <div class="mt-4 flex flex-wrap gap-4 text-sm text-[var(--color-muted)]">
        {home_base && <span>🏠 <strong class="text-[var(--color-text)]">{home_base}</strong></span>}
        <span>
          🚢&nbsp;
          {boat.link
            ? <a href={boat.link} target="_blank" rel="noopener noreferrer" class="font-semibold text-[var(--color-sea)] underline">{boat.name}</a>
            : <strong class="text-[var(--color-text)]">{boat.name}</strong>
          }
          &nbsp;{boat.length_m}м × {boat.beam_m}м · осадка {boat.draft_m}м
          {boat.water_tank_l && <>&nbsp;· вода {boat.water_tank_l}л</>}
        </span>
        <span>👥 {crew.adults} взрослых + {crew.children} детей ({crew.children_ages})</span>
        <span>📅 {dates}</span>
      </div>

      <!-- Standing rules -->
      {rules.length > 0 && (
        <ul class="mt-4 space-y-1 border-t border-[var(--color-sea-light)] pt-4">
          {rules.map((rule) => (
            <li class="flex gap-2 text-sm">
              <span class="shrink-0 text-[var(--color-sea)]">📌</span>
              <span>{rule}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Decision tree diagram -->
    <RouteDiagram />

    <!-- Day sections -->
    <div>
      {days.map((day) => <DaySection day={day} />)}
    </div>

    <!-- Scirocco branch -->
    {scirocco_branch.length > 0 && <SciroccoSection variants={scirocco_branch} />}

  </main>
</Layout>
