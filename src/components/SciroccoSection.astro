---
import type { SciroccoDay } from '../schemas/route';

interface Props {
  days: SciroccoDay[];
}

const { days } = Astro.props;
---

<section class="mt-14 rounded-2xl border-2 border-[var(--color-scirocco-border)] bg-[var(--color-scirocco)] p-6">
  <!-- Header -->
  <div class="mb-6 flex items-center gap-3">
    <span class="text-3xl">🌪️</span>
    <div>
      <h2 class="font-heading text-2xl font-bold text-[var(--color-scirocco-text)]">
        Красная Ветка — Scirocco
      </h2>
      <p class="mt-0.5 text-sm text-[var(--color-scirocco-text)] opacity-80">
        Активируется при устойчивом южном ветре начиная с Дня 3. Побережье Амальфи и юг Искьи
        становятся опасными — переход под защиту гор Сорренто.
      </p>
    </div>
  </div>

  <!-- Days -->
  <div class="space-y-4">
    {days.map((day) => (
      <div class="rounded-xl border-l-4 border-[var(--color-scirocco-border)] bg-white/60 p-4">
        <!-- Day label row -->
        <div class="mb-2 flex flex-wrap items-center gap-2">
          <span class="rounded bg-[var(--color-scirocco-border)] px-2 py-0.5 text-xs font-bold text-white">
            ДЕНЬ {day.day_ref}
          </span>
          <h3 class="font-semibold text-[var(--color-scirocco-text)]">{day.title}</h3>
          {day.merges_to && (
            <span class="ml-auto text-xs italic text-[var(--color-scirocco-text)] opacity-70">
              ↩ {day.merges_to}
            </span>
          )}
        </div>

        <!-- Destination -->
        <p class="mb-2 text-sm font-semibold">📍 {day.destination}</p>

        <!-- Mooring -->
        <div class="mb-3 rounded-md bg-white/70 px-3 py-2 text-sm">
          <span class="font-semibold">⚓ {day.mooring.name ?? day.mooring.type}</span>
          {day.mooring.notes && (
            <p class="mt-1 text-xs text-[var(--color-muted)]">{day.mooring.notes}</p>
          )}
        </div>

        <!-- Activities -->
        {day.activities.length > 0 && (
          <ul class="space-y-1">
            {day.activities.map((act) => (
              <li class="flex gap-2 text-sm leading-snug text-[var(--color-scirocco-text)]">
                <span class="mt-0.5 shrink-0">·</span>
                <span>{act}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>
</section>
