---
import type { Plan, MooringType } from '../schemas/route';

interface Props {
  plan: Plan;
  variant: 'a' | 'b';
}

const { plan, variant } = Astro.props;

const MOORING_LABELS: Record<MooringType, string> = {
  marina:          'Марина',
  buoy:            'Буй',
  anchor:          'Якорь',
  marina_or_anchor: 'Марина / Якорь',
};

const V = {
  a: {
    bg:         'bg-[var(--color-plan-a)]',
    border:     'border-[var(--color-plan-a-border)]',
    badge:      'bg-[var(--color-plan-a-border)] text-white',
    triggerClr: 'text-[var(--color-plan-a-text)]',
    label:      'ПЛАН А',
  },
  b: {
    bg:         'bg-[var(--color-plan-b)]',
    border:     'border-[var(--color-plan-b-border)]',
    badge:      'bg-[var(--color-plan-b-border)] text-[var(--color-plan-b-text)]',
    triggerClr: 'text-[var(--color-plan-b-text)]',
    label:      'ПЛАН Б',
  },
} as const;

const s = V[variant];
---

<div class={`rounded-xl border-l-4 ${s.border} ${s.bg} p-4`}>
  <!-- Header row -->
  <div class="mb-3 flex flex-wrap items-start gap-2">
    <span class={`shrink-0 rounded px-2 py-0.5 text-xs font-bold ${s.badge}`}>
      {s.label}
    </span>
    {plan.trigger && (
      <span class={`text-xs italic leading-5 ${s.triggerClr}`}>{plan.trigger}</span>
    )}
  </div>

  <!-- Destination chain -->
  <div class="mb-3 flex flex-wrap items-center gap-1">
    {plan.destinations.map((dest, i) => (
      <>
        <span class="rounded-md bg-white/70 px-2 py-0.5 text-sm font-semibold">{dest}</span>
        {i < plan.destinations.length - 1 && (
          <span class="text-[var(--color-muted)] text-xs">→</span>
        )}
      </>
    ))}
  </div>

  <!-- Mooring blocks -->
  <div class="mb-3 space-y-2">
    {plan.moorings.map((m) => (
      <div class="rounded-md bg-white/60 px-3 py-2 text-sm">
        <div class="flex flex-wrap items-center gap-1.5 font-semibold">
          <span>⚓</span>
          <span class="rounded bg-[var(--color-sea)] px-1.5 py-0.5 text-xs font-bold uppercase tracking-wide text-white">
            {MOORING_LABELS[m.type]}
          </span>
          {m.name && <span>{m.name}</span>}
          {m.phones.map((p) => (
            <a href={`tel:${p}`} class="font-normal text-[var(--color-sea)] underline">{p}</a>
          ))}
        </div>
        {m.vhf && (
          <p class="mt-1 text-xs text-[var(--color-muted)]">VHF: <strong class="text-[var(--color-text)]">{m.vhf}</strong></p>
        )}
        {m.google_map && (
          <a href={m.google_map} target="_blank" rel="noopener noreferrer"
             class="mt-1 inline-block text-xs text-[var(--color-sea)] underline hover:text-[var(--color-sea-deep)]">
            🗺 Google Maps
          </a>
        )}
        {m.notes && (
          <p class="mt-1 text-xs text-[var(--color-muted)]">{m.notes}</p>
        )}
        {m.booking_urls.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-1">
            {m.booking_urls.map((url, i) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block rounded border border-[var(--color-sea)] bg-white px-2 py-0.5 text-xs text-[var(--color-sea)] transition-colors hover:bg-[var(--color-sea-pale)]"
              >
                {i === 0 ? '📋 Забронировать' : '📋 Navily'}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Activities (legacy) -->
  {plan.activities.length > 0 && (
    <ul class="mb-2 space-y-1">
      {plan.activities.map((act) => (
        <li class="flex gap-2 text-sm leading-snug">
          <span class="mt-0.5 shrink-0 text-[var(--color-muted)]">·</span>
          <span>{act}</span>
        </li>
      ))}
    </ul>
  )}

  <!-- POIs -->
  {plan.pois.length > 0 && (
    <div class="mt-3 space-y-1.5">
      <div class="text-xs font-semibold uppercase tracking-wide text-[var(--color-muted)]">📍 Что делать</div>
      {plan.pois.map((poi, i) => (
        <div class="flex gap-2 rounded-md bg-white/60 px-3 py-2 text-sm">
          <span class="shrink-0 font-bold text-[var(--color-sea-deep)]">{i + 1}.</span>
          <div class="min-w-0">
            {poi.tripadvisor_url
              ? <a href={poi.tripadvisor_url} target="_blank" rel="noopener noreferrer"
                   class="font-medium text-[var(--color-sea)] underline hover:text-[var(--color-sea-deep)]">
                  {poi.name} ↗
                </a>
              : <span class="font-medium">{poi.name}</span>
            }
            <p class="mt-0.5 text-xs leading-snug text-[var(--color-muted)]">{poi.description}</p>
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- Warnings -->
  {plan.warnings.map((w) => (
    <div
      class={`mt-2 flex gap-2 rounded-md px-3 py-2 text-sm leading-snug ${
        w.severity === 'critical'
          ? 'bg-red-100 text-red-800'
          : w.severity === 'warning'
          ? 'bg-orange-100 text-orange-800'
          : 'bg-blue-100 text-blue-800'
      }`}
    >
      <span class="shrink-0">
        {w.severity === 'critical' ? '🚨' : w.severity === 'warning' ? '⚠️' : 'ℹ️'}
      </span>
      <span>{w.text}</span>
    </div>
  ))}

  <!-- Scirocco note -->
  {plan.scirocco_note && (
    <div class="mt-2 flex gap-2 rounded-md border border-[var(--color-scirocco-border)] bg-[var(--color-scirocco)] px-3 py-2 text-sm leading-snug text-[var(--color-scirocco-text)]">
      <span class="shrink-0">🌪️</span>
      <span>{plan.scirocco_note}</span>
    </div>
  )}
</div>
