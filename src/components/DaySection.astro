---
import type { Day } from '../schemas/route';
import POICard from './POICard.astro';
import AnchoringCard from './AnchoringCard.astro';

interface Props {
  day: Day;
}

const { day } = Astro.props;
---

<section class="page-break avoid-break">
  <!-- Day header -->
  <div class="mb-4 border-b-2 border-[var(--color-sea)] pb-3">
    <div class="flex flex-wrap items-baseline gap-3">
      <span
        class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-sea)] text-sm font-bold text-white"
      >
        {day.day}
      </span>
      <h2 class="font-heading text-2xl font-semibold">{day.title}</h2>
    </div>

    {(day.from || day.to || day.distance_nm) && (
      <div class="mt-2 flex flex-wrap gap-4 text-sm text-[var(--color-muted)]">
        {day.from && <span>From: <strong class="text-[var(--color-text)]">{day.from}</strong></span>}
        {day.to   && <span>To: <strong class="text-[var(--color-text)]">{day.to}</strong></span>}
        {day.distance_nm && <span>≈ <strong class="text-[var(--color-text)]">{day.distance_nm} nm</strong></span>}
      </div>
    )}
  </div>

  <!-- Description -->
  {day.description && (
    <p class="mb-4 leading-relaxed text-[var(--color-text)]">{day.description}</p>
  )}

  <!-- Destinations -->
  {day.destinations.length > 0 && (
    <div class="mb-4">
      <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-sea)]">
        Destinations
      </h3>
      <ul class="space-y-1">
        {day.destinations.map((dest) => (
          <li class="text-sm">
            <strong>{dest.name}</strong>
            {dest.coordinates && (
              <span class="ml-2 font-mono text-xs text-[var(--color-muted)]">
                {dest.coordinates}
              </span>
            )}
            {dest.description && (
              <span class="text-[var(--color-muted)]"> — {dest.description}</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Points of Interest -->
  {day.pois.length > 0 && (
    <div class="mb-4">
      <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-sea)]">
        Points of Interest
      </h3>
      <div class="grid gap-2 sm:grid-cols-2">
        {day.pois.map((poi) => <POICard poi={poi} />)}
      </div>
    </div>
  )}

  <!-- Anchoring -->
  {day.anchoring && <AnchoringCard anchoring={day.anchoring} />}
</section>
