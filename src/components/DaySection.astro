---
import type { Day } from '../schemas/route';
import PlanCard from './PlanCard.astro';

interface Props {
  day: Day;
}

const { day } = Astro.props;
---

<section class="page-break avoid-break mb-12">
  <!-- Day header -->
  <div class="mb-4 border-b-2 border-[var(--color-sea)] pb-3">
    <div class="flex flex-wrap items-baseline gap-3">
      <span class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-sea)] text-sm font-bold text-white">
        {day.day}
      </span>
      <div>
        <h2 class="font-heading text-2xl font-semibold">{day.title}</h2>
        <span class="text-sm text-[var(--color-muted)]">{day.date}</span>
      </div>
    </div>
    {day.departure_time && (
      <div class="mt-2 text-sm text-[var(--color-muted)]">
        Выход: <strong class="text-[var(--color-text)]">{day.departure_time}</strong>
      </div>
    )}
  </div>

  <!-- Day notes -->
  {day.notes && (
    <p class="mb-4 rounded-lg bg-[var(--color-sea-pale)] px-4 py-3 text-sm leading-relaxed text-[var(--color-text)]">
      {day.notes}
    </p>
  )}

  <!-- Plans -->
  <div class={`grid gap-4 ${day.plan_b ? 'sm:grid-cols-2' : 'grid-cols-1 max-w-xl'}`}>
    <PlanCard plan={day.plan_a} variant="a" />
    {day.plan_b && <PlanCard plan={day.plan_b} variant="b" />}
  </div>
  )}

</section>
