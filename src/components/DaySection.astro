---
import type { Day } from '../schemas/route';
import PlanCard from './PlanCard.astro';

interface Props {
  day: Day;
}

const { day } = Astro.props;
---

<section class="page-break avoid-break mb-12">
  <!-- Day header -->
  <div class="mb-4 border-b-2 border-[var(--color-sea)] pb-3">
    <div class="flex flex-wrap items-baseline gap-3">
      <span class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-sea)] text-sm font-bold text-white">
        {day.day}
      </span>
      <div>
        <h2 class="font-heading text-xl font-semibold sm:text-2xl">{day.title}</h2>
        <span class="text-sm text-[var(--color-muted)]">{day.date}</span>
      </div>
    </div>
    {day.departure_time && (
      <div class="mt-2 text-sm text-[var(--color-muted)]">
        Выход: <strong class="text-[var(--color-text)]">{day.departure_time}</strong>
      </div>
    )}
  </div>

  <!-- Day notes -->
  {day.notes && (
    <p class="mb-4 rounded-lg bg-[var(--color-sea-pale)] px-4 py-3 text-sm leading-relaxed text-[var(--color-text)]">
      {day.notes}
    </p>
  )}

  <!-- Morning POIs (pre-departure) -->
  {day.morning_pois.length > 0 && (
    <div class="mb-4">
      <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-[var(--color-muted)]">📍 До выхода</p>
      <div class="space-y-1.5">
        {day.morning_pois.map((poi, i) => (
          <div class="flex gap-2 rounded-md border border-[var(--color-sea-light)] bg-white px-3 py-2 text-sm">
            <span class="shrink-0 font-bold text-[var(--color-sea-deep)]">{i + 1}.</span>
            <div class="min-w-0">
              {poi.tripadvisor_url
                ? <a href={poi.tripadvisor_url} target="_blank" rel="noopener noreferrer"
                     class="font-medium text-[var(--color-sea)] underline hover:text-[var(--color-sea-deep)]">
                    {poi.name} ↗
                  </a>
                : <span class="font-medium">{poi.name}</span>
              }
              <p class="mt-0.5 text-xs leading-snug text-[var(--color-muted)]">{poi.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Plans -->
  <div class={`grid gap-4 ${day.plan_b ? 'sm:grid-cols-2' : 'grid-cols-1 max-w-xl'}`}>
    <PlanCard plan={day.plan_a} variant="a" />
    {day.plan_b && <PlanCard plan={day.plan_b} variant="b" />}
  </div>

</section>
