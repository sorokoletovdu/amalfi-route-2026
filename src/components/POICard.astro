---
// Legacy component — not used in current design
interface Props {
  poi: { name: string; type: string; description: string; rating?: number; link?: string };
}

const { poi } = Astro.props;

const typeEmoji: Record<string, string> = {
  cultural:  '🏛',
  beach:     '🏖',
  restaurant:'🍽',
  nature:    '🌿',
  marina:    '⚓',
  viewpoint: '👁',
  other:     '📍',
};
---

<div class="avoid-break flex gap-3 rounded-lg border border-gray-100 bg-white p-3 shadow-sm">
  <span class="text-xl leading-none">{typeEmoji[poi.type] ?? '📍'}</span>
  <div class="min-w-0 flex-1">
    <div class="flex flex-wrap items-baseline gap-2">
      <h4 class="font-medium">{poi.name}</h4>
      {poi.rating && (
        <span class="text-xs text-[var(--color-anchor-dark)]">
          {'★'.repeat(Math.round(poi.rating))} {poi.rating}
        </span>
      )}
    </div>
    <p class="mt-0.5 text-sm text-[var(--color-muted)]">{poi.description}</p>
    {poi.link && (
      <a
        href={poi.link}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-1 inline-block text-xs text-[var(--color-sea)] underline"
      >
        More info ↗
      </a>
    )}
  </div>
</div>
