---
import type { Anchoring } from '../schemas/route';

interface Props {
  anchoring: Anchoring;
}

const { anchoring } = Astro.props;
---

<div class="avoid-break rounded-lg border-l-4 border-[var(--color-anchor)] bg-[var(--color-land)] p-4">
  <h4 class="mb-2 flex items-center gap-2 font-semibold text-[var(--color-anchor-dark)]">
    <span>⚓</span> Anchoring — {anchoring.bay}
  </h4>
  <dl class="grid grid-cols-2 gap-x-6 gap-y-1 text-sm sm:grid-cols-3">
    <div>
      <dt class="text-xs font-medium uppercase text-[var(--color-muted)]">Coordinates</dt>
      <dd class="font-mono text-xs">{anchoring.coordinates}</dd>
    </div>
    <div>
      <dt class="text-xs font-medium uppercase text-[var(--color-muted)]">Depth</dt>
      <dd>{anchoring.depth_m} m</dd>
    </div>
    {anchoring.shelter && (
      <div class="col-span-2 sm:col-span-1">
        <dt class="text-xs font-medium uppercase text-[var(--color-muted)]">Shelter</dt>
        <dd>{anchoring.shelter}</dd>
      </div>
    )}
  </dl>
  {anchoring.notes && (
    <p class="mt-2 text-sm text-[var(--color-text)]">{anchoring.notes}</p>
  )}
</div>
