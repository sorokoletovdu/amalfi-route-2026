---
import { getCollection } from 'astro:content';
import type { Route } from '../schemas/route';

const entries = await getCollection('route');
const route = entries[0]?.data as Route;

/** Replace double-quotes with single-quotes so Mermaid label strings don't break. */
function q(s: string): string {
  return s.replace(/"/g, "'");
}

const MOORING_LABELS: Record<string, string> = {
  marina:          'Марина',
  buoy:            'Буй',
  anchor:          'Якорь',
  marina_or_anchor: 'Марина/Якорь',
};

function mooringLabel(moorings: Route['days'][0]['plan_a']['moorings']): string {
  const last = moorings[moorings.length - 1];
  if (!last) return '';
  const t = MOORING_LABELS[last.type] ?? last.type;
  return last.name ? `[${t}] ${q(last.name)}` : t;
}

function generateDiagram(r: Route): string {
  const lines: string[] = [
    'graph TD',
    '  classDef planA fill:#d4edda,stroke:#28a745,stroke-width:2px;',
    '  classDef planB fill:#fff3cd,stroke:#ffc107,stroke-width:2px;',
    '  classDef scirocco fill:#f8d7da,stroke:#dc3545,stroke-width:2px;',
    '  classDef condition fill:#e2e3e5,stroke:#6c757d,stroke-width:1px;',
    '  classDef base fill:#cce5ff,stroke:#007bff,stroke-width:2px;',
    '',
  ];

  const home = q(r.home_base ?? '');
  const first = r.days[0];

  // Start node
  lines.push(`  Start["${first?.date ?? ''}<br/>База: ${home}"]:::base`);

  // Track which nodes the next step should connect from.
  // After days with both Plan A and Plan B, both nodes feed forward.
  let prev: string[] = ['Start'];

  for (const day of r.days) {
    const id = `D${day.day}`;

    if (day.plan_b) {
      const condId = `${id}C`;
      const condLabel = q(day.plan_a.trigger ?? `День ${day.day}?`);
      lines.push(`  ${condId}{"${condLabel}"}:::condition`);
      prev.forEach(p => lines.push(`  ${p} --> ${condId}`));

      const aId = `${id}A`;
      const bId = `${id}B`;

      const aLabel =
        `День ${day.day} · ${q(day.plan_a.destinations.join(' - '))}<br/>` +
        mooringLabel(day.plan_a.moorings);
      const bLabel =
        `День ${day.day} Б · ${q(day.plan_b.destinations.join(' - '))}<br/>` +
        mooringLabel(day.plan_b.moorings);

      lines.push(`  ${condId} -- "Да" --> ${aId}["${aLabel}"]:::planA`);
      lines.push(`  ${condId} -- "Нет" --> ${bId}["${bLabel}"]:::planB`);

      prev = [aId, bId];
    } else {
      const aId = `${id}A`;
      const aLabel =
        `День ${day.day} · ${q(day.plan_a.destinations.join(' - '))}<br/>` +
        mooringLabel(day.plan_a.moorings);

      prev.forEach(p => lines.push(`  ${p} --> ${aId}["${aLabel}"]:::planA`));
      prev = [aId];
    }
  }

  // End node
  const last = r.days[r.days.length - 1];
  lines.push(`  End["${last?.date ?? ''}<br/>Финиш: ${home}"]:::base`);
  prev.forEach(p => lines.push(`  ${p} --> End`));

  // Scirocco variants as clearly-labelled disconnected nodes
  if (r.scirocco_branch.length > 0) {
    lines.push('');
    r.scirocco_branch.forEach((v, i) => {
      const sciId = `Sci${i + 1}`;
      const label =
        `Scirocco ${i + 1}: ${q(v.title)}<br/>${q(v.condition)}<br/>Укрытие: ${q(v.shelter)}`;
      lines.push(`  ${sciId}["${label}"]:::scirocco`);
    });
  }

  return lines.join('\n');
}

const diagram = generateDiagram(route);
---

<div class="route-diagram mb-10 rounded-xl border border-[var(--color-sea-light)] bg-white p-3 shadow-sm sm:p-5">
  <!-- Legend -->
  <div class="mb-3 flex flex-wrap gap-4 text-sm">
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded border border-[var(--color-plan-a-border)] bg-[var(--color-plan-a)]"></span>
      <span>План А</span>
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded border border-[var(--color-plan-b-border)] bg-[var(--color-plan-b)]"></span>
      <span>План Б</span>
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded border border-[var(--color-scirocco-border)] bg-[var(--color-scirocco)]"></span>
      <span>Scirocco (южный ветер)</span>
    </span>
  </div>

  <!-- Accordion -->
  <details class="group">
    <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg bg-[var(--color-sea-pale)] px-4 py-2.5 text-sm font-semibold text-[var(--color-sea-deep)] hover:bg-[var(--color-sea-light)]/40 select-none">
      <span>🗺️ Схема маршрута: дерево решений</span>
      <span class="transition-transform duration-200 group-open:rotate-180">▾</span>
    </summary>

    <div class="mt-3">
      <!-- Mermaid renders here; content injected by script below -->
      <div id="mermaid-chart" class="overflow-auto text-sm"></div>
      <div class="mt-2 text-right">
        <a
          href="/route-diagram.html"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-[var(--color-sea)] underline hover:text-[var(--color-sea-deep)]"
        >
          Открыть полный экран ↗
        </a>
      </div>
    </div>
  </details>
</div>

<script is:inline define:vars={{ diagram }}>
(function () {
  function injectAndRender() {
    var el = document.getElementById('mermaid-chart');
    if (!el) return;
    el.textContent = diagram;
    el.classList.add('mermaid');
    // @ts-ignore
    if (typeof mermaid !== 'undefined') {
      // @ts-ignore
      mermaid.run({ nodes: [el] });
    }
  }

  // Load Mermaid only when the accordion is first opened (lazy)
  var details = document.querySelector('.route-diagram details');
  if (details) {
    details.addEventListener('toggle', function onToggle() {
      if (!details.open) return;
      details.removeEventListener('toggle', onToggle);
      // @ts-ignore
      if (typeof mermaid !== 'undefined') {
        injectAndRender();
        return;
      }
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/mermaid@10.9.6/dist/mermaid.min.js';
      s.onload = function () {
        // @ts-ignore
        mermaid.initialize({ startOnLoad: false, theme: 'default', securityLevel: 'loose' });
        injectAndRender();
      };
      document.head.appendChild(s);
    });
  }
})();
</script>
